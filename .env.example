# OneLake / Fabric
FABRIC_WORKSPACE_ID=your-workspace-guid
FABRIC_LAKEHOUSE_ID=your-lakehouse-guid

# Folder mapping under the lakehouse path
# Example for https://onelake.dfs.fabric.microsoft.com/<workspace>/<lakehouse>/Files/EFT
# Script behavior:
# - Creates local txt sample files under ./data
# - Uploads them to inbox, copies to outbox, then downloads outbox files to ./data/download
FABRIC_BASE_FOLDER=Files/Folder
FABRIC_INBOX_FOLDER=inbox
FABRIC_OUTBOX_FOLDER=outbox
FABRIC_PAUSE_UPLOAD=true
FABRIC_PAUSE_CLEANUP=true
FABRIC_ENABLE_CLEANUP=false

# Service Principal
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
